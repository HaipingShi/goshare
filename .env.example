# Local development example.
# Copy this file to .dev.vars for Wrangler or .env for the legacy Express server.

APP_NAME=goshare
APP_DESCRIPTION=分享 AI 生成内容的最佳方式
APP_LOGO_URL=/icon/web/icon-512.png
APP_FOOTER_TEXT=
APP_FOOTER_URL=
APP_REPO_URL=https://github.com/HaipingShi/goshare
PUBLIC_SITE_URL=http://127.0.0.1:8787

AUTH_ENABLED=false
AUTH_PASSWORD=replace-with-a-local-password
COOKIE_SECRET=replace-with-openssl-rand-hex-32
COOKIE_PREFIX=goshare
AGENT_API_TOKEN=replace-with-agent-api-token

AI_ENABLED=true
AI_BEAUTIFY_MODEL=@cf/zai-org/glm-4.7-flash
MAX_BEAUTIFY_CONTENT_KB=120
AI_SHARE_METADATA_ENABLED=true
AI_SHARE_METADATA_MODEL=@cf/zai-org/glm-4.7-flash
MAX_SHARE_METADATA_CONTENT_KB=24

NODE_ENV=development
PORT=5678
LOG_LEVEL=dev
